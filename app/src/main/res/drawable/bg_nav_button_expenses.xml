<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Shadow layer -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="50dp" />
            <solid android:color="#33000000" />
            <size android:height="48dp" android:width="120dp" />
        </shape>
    </item>
    <!-- Button background with gradient for depth -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="50dp" />
            <gradient
                android:startColor="@color/nav_blue_start"
                android:endColor="@color/nav_blue_end"
                android:angle="90" />
            <size android:height="48dp" android:width="120dp" />
        </shape>
    </item>

    <!-- Highlight overlay for shiny effect -->
    <item android:bottom="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="50dp" />
            <gradient
                android:startColor="#66FFFFFF"
                android:endColor="#00FFFFFF"
                android:angle="45" />
        </shape>
    </item>
</layer-list>