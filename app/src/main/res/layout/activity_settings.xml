<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="48dp"
        android:paddingBottom="0dp">

        <!-- Account Section -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAccount"
            style="@style/Widget.BudgetBrewer.SettingsSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_account"
            android:textColor="@color/text_on_main"
            app:icon="@drawable/ic_chevron_right"
            app:iconGravity="textEnd"
            app:iconTint="@color/text_on_main" />

        <LinearLayout
            android:id="@+id/accountContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="8dp"
            android:paddingEnd="16dp"
            android:paddingBottom="8dp"
            android:visibility="gone">
            <!-- account content unchanged -->
            <TextView
                android:id="@+id/tvAccountStatus"
                style="@style/TextAppearance.BudgetBrewer.Body"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/not_signed_in" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSignIn"
                style="@style/Widget.BudgetBrewer.Button.Main"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:text="@string/sign_in"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSignUp"
                style="@style/Widget.BudgetBrewer.Button.Main"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:text="@string/sign_up"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvUserEmail"
                style="@style/TextAppearance.BudgetBrewer.Body"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSignOut"
                style="@style/Widget.BudgetBrewer.Button.Container"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="@string/sign_out"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnExportCSV"
                style="@style/Widget.BudgetBrewer.Button.Container"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="@string/export_csv"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnExportPDF"
                style="@style/Widget.BudgetBrewer.Button.Container"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="@string/export_pdf"
                android:visibility="gone" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchPinLock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/enable_pin_lock"
                android:fontFamily="@font/exo_regular"
                android:textColor="@color/text_on_main"
                android:visibility="gone" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchBiometrics"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/enable_biometrics"
                android:fontFamily="@font/exo_regular"
                android:textColor="@color/text_on_main"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnChangePin"
                style="@style/Widget.BudgetBrewer.Button.Container"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="@string/change_pin"
                android:fontFamily="@font/exo_regular"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDeletePin"
                style="@style/Widget.BudgetBrewer.Button.Container"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="@string/delete_pin"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Appearance Section -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAppearance"
            style="@style/Widget.BudgetBrewer.SettingsSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/settings_appearance"
            android:textColor="@color/text_on_main"
            app:icon="@drawable/ic_chevron_right"
            app:iconGravity="textEnd"
            app:iconTint="@color/text_on_main" />

        <LinearLayout
            android:id="@+id/themeButtonContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingTop="8dp"
            android:paddingEnd="16dp"
            android:paddingBottom="8dp"
            android:visibility="gone">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnThemeLight"
                style="@style/Widget.BudgetBrewer.TimeframeButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="@string/light"
                android:background="@drawable/bg_theme_button_light"
                android:checkable="true" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnThemeDark"
                style="@style/Widget.BudgetBrewer.TimeframeButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="@string/dark"
                android:background="@drawable/bg_theme_button_dark"
                android:checkable="true" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnThemeSystem"
                style="@style/Widget.BudgetBrewer.TimeframeButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="@string/system"
                android:background="@drawable/bg_theme_button_system"
                android:checkable="true" />
        </LinearLayout>

        <!-- Currency Section -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCurrency"
            style="@style/Widget.BudgetBrewer.SettingsSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/settings_currency"
            android:textColor="@color/text_on_main"
            app:icon="@drawable/ic_chevron_right"
            app:iconGravity="textEnd"
            app:iconTint="@color/text_on_main" />

        <Spinner
            android:id="@+id/spinnerCurrency"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:paddingStart="16dp"
            android:paddingTop="8dp"
            android:paddingEnd="16dp"
            android:paddingBottom="8dp"
            android:visibility="gone"
            android:background="@drawable/spinner_background"
            android:popupBackground="@drawable/popup_background_rounded"
            android:dropDownWidth="160dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Delete Account Button (visible only when signed in) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDeleteAccount"
            style="@style/Widget.BudgetBrewer.Button.Container"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp"
            android:text="@string/delete_account"
            android:visibility="gone" />

        <!-- Ko‑Fi Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnKoFi"
            style="@style/Widget.BudgetBrewer.Button.Main"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="8dp"
            android:text="@string/buy_me_a_coffee" />

        <!-- App Version -->
        <TextView
            android:id="@+id/tvVersion"
            style="@style/TextAppearance.BudgetBrewer.BodySmall"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="16dp"
            android:text="@string/version_placeholder" />

        <!-- Bottom spacer (ensures content is above bottom nav) -->
        <View
            android:layout_width="match_parent"
            android:layout_height="@dimen/spacer_bottom"
            android:visibility="invisible" />

    </LinearLayout>
</ScrollView>