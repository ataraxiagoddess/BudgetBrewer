<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="@color/bg_main">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textColor="@color/text_on_main"
        android:textSize="32sp"
        android:fontFamily="@font/blkchcry"
        android:layout_marginBottom="32dp" />

    <TextView
        android:id="@+id/tvPrompt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/enter_pin"
        android:textColor="@color/text_on_main"
        android:textSize="18sp"
        android:fontFamily="@font/exo_regular"
        android:layout_marginBottom="16dp" />

    <!-- PIN field with visibility toggle (like sign‑in) -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp">

        <EditText
            android:id="@+id/etPin"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="@string/pin"
            android:inputType="numberPassword"
            android:maxLength="4"
            android:background="@drawable/edittext_background"
            android:paddingHorizontal="12dp"
            android:paddingVertical="12dp"
            android:paddingEnd="48dp"
            android:textColorHint="@color/text_disabled"
            android:textColor="@color/text_on_container"
            android:fontFamily="@font/exo_regular"
            android:textSize="14sp"
            android:includeFontPadding="false"
            android:gravity="center_vertical" />

        <ImageButton
            android:id="@+id/btnTogglePassword"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="end|center_vertical"
            android:layout_marginEnd="4dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_visibility_off"
            android:contentDescription="@string/toggle_password_visibility"
            app:tint="@color/ic_button_tint" />
    </FrameLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnUnlock"
        style="@style/Widget.BudgetBrewer.Button.Main"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:text="@string/unlock"
        android:layout_marginBottom="16dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnBiometric"
        style="@style/Widget.BudgetBrewer.Button.Container"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:text="@string/use_biometrics"
        android:visibility="gone" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCancel"
        style="@style/Widget.BudgetBrewer.Button.Container"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:text="@string/cancel" />

</LinearLayout>