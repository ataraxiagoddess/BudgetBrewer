<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:paddingHorizontal="16dp">

    <!-- Back button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnBack"
        style="@style/Widget.BudgetBrewer.Button.Container"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"
        android:paddingStart="12dp"
        android:paddingEnd="16dp"
        android:text="@string/back"
        app:icon="@drawable/ic_chevron_left"
        app:iconGravity="textStart" />

    <!-- Centered content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingHorizontal="16dp">

        <ImageView
            android:id="@+id/ivAppIcon"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:layout_marginBottom="16dp"
            android:src="@drawable/budget_brewer_logo" />

        <TextView
            android:id="@+id/tvAppName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:fontFamily="@font/blkchcry"
            android:text="@string/app_name"
            android:textColor="@color/text_on_main"
            android:textSize="32sp" />

        <TextView
            android:id="@+id/tvEmailSent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_on_main"
            android:textSize="16sp"
            android:fontFamily="@font/exo_regular"
            android:layout_marginBottom="24dp"
            android:gravity="center" />

        <!-- Code input – now with maxWidth to avoid edge‑to‑edge -->
        <EditText
            android:id="@+id/etCode"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_gravity="center"
            android:maxWidth="280dp"
            android:hint="@string/verification_code"
            android:inputType="number"
            android:maxLength="6"
            android:background="@drawable/edittext_background"
            android:paddingHorizontal="12dp"
            android:paddingVertical="12dp"
            android:textColorHint="@color/text_disabled"
            android:textColor="@color/text_on_container"
            android:fontFamily="@font/exo_regular"
            android:textSize="14sp"
            android:includeFontPadding="false"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp" />

        <!-- Verify button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnVerify"
            style="@style/Widget.BudgetBrewer.Button.Main"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="@string/verify"
            android:layout_marginBottom="8dp" />

        <!-- Resend link -->
        <TextView
            android:id="@+id/btnResend"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/resend_code"
            android:textColor="@color/text_on_main"
            android:textSize="14sp"
            android:clickable="true"
            android:focusable="true"
            android:fontFamily="@font/exo_regular"
            android:padding="8dp"
            android:layout_marginBottom="16dp" />

        <!-- Hint for users who are already verified -->
        <TextView
            android:id="@+id/tvHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/verification_hint"
            android:textColor="@color/text_on_main"
            android:textSize="14sp"
            android:fontFamily="@font/exo_regular"
            android:gravity="center"
            android:paddingTop="16dp"
            android:paddingBottom="8dp"
            android:maxWidth="300dp" />

        <!-- Sign in instead link -->
        <TextView
            android:id="@+id/tvSignInInstead"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/sign_in_instead"
            android:textColor="@color/text_on_main"
            android:textSize="14sp"
            android:clickable="true"
            android:focusable="true"
            android:fontFamily="@font/exo_regular"
            android:padding="8dp"
            android:textStyle="bold" />

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone"
            android:layout_marginTop="16dp" />

    </LinearLayout>

</LinearLayout>