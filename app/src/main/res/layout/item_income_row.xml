<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingVertical="2dp"
    android:paddingHorizontal="8dp"
    android:layout_marginBottom="1dp"
    android:gravity="center_vertical"
    android:background="@null">

    <!-- Time frame column – wraps content, max width to allow two lines -->
    <TextView
        android:id="@+id/tvTimeFrame"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxWidth="70dp"
        android:maxLines="2"
        android:ellipsize="end"
        style="@style/TextAppearance.BudgetBrewer.Subtext"
        android:textColor="@color/text_on_container"
        android:layout_marginEnd="2dp"
        android:gravity="start"
        android:background="@null"/>

    <!-- Source column – reduced left padding -->
    <TextView
        android:id="@+id/tvSource"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        style="@style/TextAppearance.BudgetBrewer.Body"
        android:textColor="@color/text_on_container"
        android:paddingStart="2dp"
        android:paddingEnd="2dp"
        android:maxLines="1"
        android:ellipsize="end"
        android:gravity="start"
        android:background="@null"/>

    <!-- Amount column – reduced right margin -->
    <TextView
        android:id="@+id/tvAmount"
        android:layout_width="70dp"
        android:layout_height="wrap_content"
        style="@style/TextAppearance.BudgetBrewer.Body"
        android:textColor="@color/text_on_container"
        android:layout_marginEnd="4dp"
        android:maxLines="1"
        android:ellipsize="end"
        android:gravity="end"
        android:background="@null"/>

    <!-- Add Income button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAddIncome"
        style="@style/Widget.BudgetBrewer.Button.Container"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:text="@string/add_income_button"
        android:visibility="gone"
        app:icon="@null" />

    <!-- Edit button -->
    <ImageButton
        android:id="@+id/btnEditIncome"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@android:drawable/ic_menu_edit"
        app:tint="@color/edit_icon_color"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/edit"
        android:visibility="gone" />

    <!-- Delete button -->
    <ImageButton
        android:id="@+id/btnDeleteIncome"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@android:drawable/ic_menu_delete"
        app:tint="@color/delete_icon_color"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/delete"
        android:visibility="gone" />
</LinearLayout>