<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="8dp"
    android:paddingStart="8dp"
    android:background="@drawable/category_background"
    android:layout_marginBottom="2dp"
    android:gravity="center_vertical">

    <!-- Day number column - fixed width, centered -->
    <TextView
        android:id="@+id/tvDayNumber"
        style="@style/TextAppearance.BudgetBrewer.Body.Container"
        android:layout_width="40dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textSize="16sp"
        android:textStyle="bold" />

    <!-- Expenses column - takes remaining space -->
    <TextView
        android:id="@+id/tvExpenses"
        style="@style/TextAppearance.BudgetBrewer.Body.Container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:lineSpacingExtra="2dp" />

    <!-- Checkbox column - fixed width -->
    <CheckBox
        android:id="@+id/checkbox"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:buttonTint="@color/ic_button_tint"
        android:visibility="visible" />

</LinearLayout>