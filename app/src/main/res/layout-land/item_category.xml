<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/category_background"
    android:orientation="vertical"
    android:padding="4dp">   <!-- Reduced from 8dp to 4dp -->

    <!-- Category Header Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvCategoryName"
            style="@style/TextAppearance.BudgetBrewer.Subheader"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:textColor="@color/text_on_container" />

        <ImageButton
            android:id="@+id/btnEditCategory"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/edit"
            android:src="@android:drawable/ic_menu_edit"
            app:tint="@color/ic_button_tint" />

        <ImageButton
            android:id="@+id/btnDeleteCategory"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/delete"
            android:src="@android:drawable/ic_menu_delete"
            app:tint="@color/ic_button_tint" />
    </LinearLayout>

    <!-- Scrollable expenses container with fixed height -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/expensesScrollView"
        android:layout_width="match_parent"
        android:layout_height="@dimen/expenses_scrollview_max_height"
        android:scrollbars="vertical"
        android:fadeScrollbars="false"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="4dp">

        <LinearLayout
            android:id="@+id/expensesContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </androidx.core.widget.NestedScrollView>

    <!-- Add Expense Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAddExpense"
        style="@style/Widget.BudgetBrewer.Button.Container"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:layout_gravity="end"
        android:layout_marginTop="4dp"
        android:text="@string/add_expense_button" />

</LinearLayout>