<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:baselineAligned="false">

        <!-- Left column: Calendar -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:orientation="vertical">

            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/spacer_top"
                android:visibility="invisible" />

            <!-- Day Header -->
            <LinearLayout
                android:id="@+id/dayHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingVertical="8dp"
                android:gravity="center" />

            <!-- CalendarView -->
            <com.kizitonwose.calendar.view.CalendarView
                android:id="@+id/calendarView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cv_dayViewResource="@layout/calendar_day_layout" />
        </LinearLayout>

        <!-- Right column: Info panel -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:orientation="vertical">

            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/spacer_top"
                android:visibility="invisible" />

            <!-- Legend -->
            <LinearLayout
                android:id="@+id/legendContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingVertical="16dp"
                android:paddingHorizontal="8dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/category_background">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginEnd="16dp">
                    <ImageView
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:src="@drawable/circle_expense"
                        android:layout_gravity="center_vertical"
                        android:layout_marginEnd="4dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/legend_expenses"
                        style="@style/TextAppearance.BudgetBrewer.Body"
                        android:textColor="@color/text_on_container" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginEnd="16dp">
                    <ImageView
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:src="@drawable/circle_spending"
                        android:layout_gravity="center_vertical"
                        android:layout_marginEnd="4dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/legend_spending"
                        style="@style/TextAppearance.BudgetBrewer.Body"
                        android:textColor="@color/text_on_container" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <ImageView
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:src="@drawable/circle_income"
                        android:layout_gravity="center_vertical"
                        android:layout_marginEnd="4dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/legend_income"
                        style="@style/TextAppearance.BudgetBrewer.Body"
                        android:textColor="@color/text_on_container" />
                </LinearLayout>
            </LinearLayout>

            <!-- Month Start Amount -->
            <LinearLayout
                android:id="@+id/monthStartRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/category_background"
                android:padding="12dp"
                android:layout_marginBottom="8dp"
                android:visibility="gone" />

            <!-- Month End Amount -->
            <LinearLayout
                android:id="@+id/monthEndRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/category_background"
                android:padding="12dp"
                android:visibility="gone" />

            <!-- Week End Totals Header -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/week_end_totals"
                style="@style/TextAppearance.BudgetBrewer.Subheader"
                android:layout_marginBottom="8dp"
                android:textColor="@color/text_on_main" />

            <!-- Week End Totals Grid (2 columns) -->
            <LinearLayout
                android:id="@+id/weekEndGridContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="0dp"
                android:orientation="vertical"
                android:layout_marginBottom="8dp" />

            <!-- Bottom spacer -->
            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/spacer_bottom"
                android:visibility="invisible" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>